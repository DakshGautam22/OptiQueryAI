# Application General Settings
APP_NAME="OptiQuery AI"
DEBUG=true
ENVIRONMENT="development"
PORT=8000

# Database Settings
# Note: alembic and FastAPI both use the async driver (asyncpg)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/optiquery_ai"

# Security & Authentication
# Generate a secret key using: openssl rand -hex 32
JWT_SECRET_KEY="placeholder_super_secret_jwt_key_change_in_production_32_bytes_length"
JWT_ALGORITHM="RS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_PRIVATE_KEY_PATH="jwt_private.pem"
JWT_PUBLIC_KEY_PATH="jwt_public.pem"

# AES-256 Encryption Key for Database Connections (Host, Username, Password)
# Must be a 32-byte key encoded in url-safe base64. Generate using: cryptography.fernet.Fernet.generate_key().decode()
DATABASE_ENCRYPTION_KEY="placeholder_32_byte_base64_encryption_key_for_db_creds="
CREDENTIAL_ENCRYPTION_KEY="placeholder_32_byte_base64_encryption_key_for_db_creds="

# AI / OpenAI Credentials
OPENAI_API_KEY="sk-proj-placeholderopenapikeyforoptiqueryai"

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIRECTORY="./chroma_db"
